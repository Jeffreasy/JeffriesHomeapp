{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:unit",
    "test:unit": "playwright test --config=playwright.unit.config.ts",
    "test:e2e": "playwright test --project=security-chromium",
    "test:e2e:authenticated": "playwright test --project=auth-desktop --project=auth-tablet --project=auth-mobile --project=auth-non-owner",
    "test:e2e:non-owner": "playwright test --project=auth-non-owner",
    "check:performance": "node scripts/check-performance-budget.mjs",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "eslint --max-warnings=0 ."
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@serwist/next": "^9.5.11",
    "@serwist/precaching": "^9.5.11",
    "@serwist/sw": "^9.5.11",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/speed-insights": "2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.10",
    "pdfjs-dist": "^4.10.38",
    "react": "19.2.7",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.7",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@clerk/testing": "2.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.13.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "googleapis": "173.0.0",
    "orval": "^8.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  }
}
