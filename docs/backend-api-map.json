{
  "name": "Jeffries Homeapp Backend API",
  "updated": "2026-06-03",
  "frontendBasePath": "/api/backend",
  "directBackendBasePath": "/api/v1",
  "renderBackendUrl": "https://jeffriesbackend.onrender.com/api/v1",
  "publicRoutes": [
    { "method": "GET", "path": "/" },
    { "method": "HEAD", "path": "/" },
    { "method": "GET", "path": "/health" },
    { "method": "GET", "path": "/swagger/*" }
  ],
  "auth": {
    "directBackend": "Private /api/v1 routes require X-API-Key.",
    "frontend": "Browser code calls /api/backend. The Next.js proxy injects X-API-Key server-side.",
    "serverEnvVars": ["BACKEND_API_URL", "BACKEND_API_KEY", "APP_SECRET_KEY"],
    "legacyFallbackEnvVars": ["NEXT_PUBLIC_API_KEY"]
  },
  "sourceFiles": {
    "frontendProxy": "app/api/backend/[...path]/route.ts",
    "manualClient": "lib/api.ts",
    "generatedClients": "lib/api/generated",
    "generatedModels": "lib/api/model",
    "orvalConfig": "orval.config.ts",
    "backendRoutesCandidates": [
      "../JeffriesBackend-render-fix/backend/internal/server/routes.go",
      "../JeffriesBackend/backend/internal/server/routes.go"
    ],
    "backendSwaggerCandidates": [
      "BACKEND_SWAGGER_PATH",
      "../JeffriesBackend-render-fix/backend/docs/swagger.json",
      "../JeffriesBackend/backend/docs/swagger.json"
    ]
  },
  "groups": [
    {
      "name": "system",
      "endpoints": [
        { "methods": ["GET"], "path": "/health", "public": true }
      ]
    },
    {
      "name": "rooms",
      "queryParams": ["skip", "limit"],
      "endpoints": [
        { "methods": ["GET", "POST"], "path": "/rooms" },
        { "methods": ["GET", "PATCH", "DELETE"], "path": "/rooms/{roomID}" }
      ]
    },
    {
      "name": "devices",
      "queryParams": ["skip", "limit"],
      "endpoints": [
        { "methods": ["GET"], "path": "/devices" },
        { "methods": ["GET", "PATCH", "DELETE"], "path": "/devices/{deviceID}" },
        { "methods": ["POST"], "path": "/devices/register" },
        { "methods": ["POST"], "path": "/devices/{deviceID}/command" }
      ]
    },
    {
      "name": "scenes",
      "queryParams": ["skip", "limit"],
      "endpoints": [
        { "methods": ["GET", "POST"], "path": "/scenes" },
        { "methods": ["GET", "DELETE"], "path": "/scenes/{sceneID}" },
        { "methods": ["POST"], "path": "/scenes/{sceneID}/activate" }
      ]
    },
    {
      "name": "automations",
      "queryParams": ["userId", "group"],
      "endpoints": [
        { "methods": ["GET", "POST"], "path": "/automations" },
        { "methods": ["PUT", "DELETE"], "path": "/automations/{id}" },
        { "methods": ["POST"], "path": "/automations/{id}/toggle" },
        { "methods": ["DELETE"], "path": "/automations/group" }
      ]
    },
    {
      "name": "schedule",
