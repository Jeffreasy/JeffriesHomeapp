        { "methods": ["GET"], "path": "/notes/search" },
        { "methods": ["GET"], "path": "/notes/tags" },
        { "methods": ["GET", "PATCH", "DELETE"], "path": "/notes/{id}" },
        { "methods": ["GET"], "path": "/notes/{id}/backlinks" }
      ]
    },
    {
