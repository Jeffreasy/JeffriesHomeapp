        { "methods": ["GET"], "path": "/schedule/date/{date}" },
        { "methods": ["POST"], "path": "/schedule/import" }
      ]
    },
    {
      "name": "transactions",
      "queryParams": ["userId", "ibanFilter", "jaarFilter", "categorieFilter", "richting", "datumVan", "datumTot", "zoekterm", "limit", "offset"],
      "endpoints": [
        { "methods": ["GET"], "path": "/transactions" },
        { "methods": ["GET"], "path": "/transactions/stats" },
        { "methods": ["POST"], "path": "/transactions/import" },
        { "methods": ["PATCH"], "path": "/transactions/{txID}" }
      ]
    },
    {
