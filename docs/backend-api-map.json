        { "methods": ["PATCH"], "path": "/laventecare/projects/{id}" },
        { "methods": ["GET", "POST"], "path": "/laventecare/actions" },
        { "methods": ["PATCH"], "path": "/laventecare/actions/{id}/status" },
        { "methods": ["POST"], "path": "/laventecare/signals/convert-lead" },
        { "methods": ["POST"], "path": "/laventecare/documents/seed" }
