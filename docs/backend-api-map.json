      "queryParams": ["limit", "q"],
      "endpoints": [
        { "methods": ["GET"], "path": "/laventecare/cockpit" },
        { "methods": ["GET"], "path": "/laventecare/documents" },
        { "methods": ["GET", "POST"], "path": "/laventecare/leads" },
        { "methods": ["PATCH"], "path": "/laventecare/leads/{id}" },
        { "methods": ["POST"], "path": "/laventecare/leads/{id}/convert" },
